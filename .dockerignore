# =============================================================================
# .dockerignore - Prediction Market
# Files and directories to exclude from Docker build context
# =============================================================================

# Dependencies (will be installed in container)
node_modules
**/node_modules

# Build outputs (will be generated in container)
dist
**/dist
.next
**/.next
out
**/out

# Development files
.git
.gitignore
.github
*.md
!README.md
LICENSE

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# Environment files (secrets should be passed at runtime)
.env
.env.*
!.env.example

# Test files
coverage
**/coverage
*.test.ts
*.spec.ts
**/*.test.ts
**/*.spec.ts
jest.config.*
test
**/test

# Debug and logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Docker files (avoid recursive copying)
Dockerfile*
docker-compose*.yml
.docker

# Documentation
docs
*.md
!apps/*/README.md

# Misc
*.tgz
*.tar.gz
.turbo
.vercel
.cache
tmp
temp
